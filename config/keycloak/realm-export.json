{
  "realm": "idabus",
  "enabled": true,
  "displayName": "Idabus Local Realm",
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard application user"
      },
      {
        "name": "admin",
        "description": "Application administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "idabus-app",
      "name": "Idabus App",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*",
        "https://localhost:8080/*",
        "http://localhost:8090/*",
        "https://localhost:8090/*",
        "http://localhost:4200/*",
        "https://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://localhost:8080",
        "http://localhost:8090",
        "https://localhost:8090",
        "http://localhost:4200",
        "https://localhost:4200"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "aud-idabus-app",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "idabus-app",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "idabus.user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Idabus",
      "lastName": "User",
      "email": "idabus.user@idabus.local",
      "credentials": [
        {
          "type": "password",
          "value": "Idabus_Password_123!",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "id": "f4023ee6-39c1-4705-be4d-4e664381b305",
      "username": "idabus.admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Idabus",
      "lastName": "Admin",
      "email": "idabus.admin@idabus.local",
      "credentials": [
        {
          "type": "password",
          "value": "Idabus_Password_123!",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    }
  ]
}
